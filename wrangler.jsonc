{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cvita",
  "main": "src/index.js",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
